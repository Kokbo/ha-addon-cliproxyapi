#!/bin/bash
export PATH=/usr/local/bin:/usr/bin:/bin
export CLIPROXY_AUTH_DIR=/config/cliproxyapi/.cli-proxy-api
export CLIPROXY_CONFIG=/config/cliproxyapi/config.yaml

cd "${HOME:-/root}" 2>/dev/null || cd /

cat <<'BANNER'
=========================================================
 CLIProxyAPI auth shell
 Config:    /config/cliproxyapi/config.yaml      ($CLIPROXY_CONFIG)
 Auth dir:  /config/cliproxyapi/.cli-proxy-api/  ($CLIPROXY_AUTH_DIR)

 Helpers (all in /usr/local/bin, tab-completable):
   claude-login        Claude Code OAuth (paste-back flow)
   codex-login         Codex device-code flow (no callback needed)
   codex-oauth-login   Codex web OAuth (needs reachable callback port)
   gemini-login        Google OAuth (callback to localhost; see README)
   antigravity-login   Antigravity OAuth
   kimi-login          Kimi OAuth
   list-auths          show token files in the auth dir
   edit-config         vi the runtime config
   restart-api         bounce the CLIProxyAPI server
   show-api-log        tail the API service log (if any)

 After login completes successfully, run: restart-api
=========================================================
BANNER

exec bash --login -i
